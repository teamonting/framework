{
  "name": "@onting/selenium-webdriver-message-port",
  "version": "0.0.0-0",
  "description": "",
  "license": "MIT",
  "author": "William Wong",
  "type": "module",
  "exports": {
    "./browser.js": {
      "import": "./dist/browser.js"
    },
    "./host.js": {
      "import": "./src/host/index.ts"
    }
  },
  "scripts": {
    "build": "npm run build:cp && npm run build:tsup",
    "build:cp": "mkdir -p ./dist/ && cp ./static/** ./dist/",
    "build:tsup": "tsup --config tsup.config.ts",
    "docker": "cd ./test/ && docker compose up",
    "start": "npx --offline serve dist",
    "test": "node --test ./test/scenario/**/*.ts"
  },
  "devDependencies": {
    "@testduet/given-when-then": "^0.1.0",
    "@testduet/wait-for": "^0.1.1",
    "@types/node": "^25.9.1",
    "@types/selenium-webdriver": "^4.35.5",
    "expect": "^30.4.1",
    "selenium-webdriver": "^4.44.0",
    "serve": "^14.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  }
}
